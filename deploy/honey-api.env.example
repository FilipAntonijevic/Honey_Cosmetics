# Production environment for Honey Cosmetics API (Hetzner)
# Copy to server: /etc/honey-api.env
# NEVER commit real secrets to git.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5128

ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=honey_cosmetics;Username=postgres;Password=CHANGE_ME

Jwt__Secret=CHANGE_TO_LONG_RANDOM_SECRET

# --- Brevo (REQUIRED for email) ---
# Create API key: Brevo → SMTP & API → API keys → Generate
Brevo__ApiKey=CHANGE_ME
# Default From (porudžbine, registracija, reset lozinke, kontakt forma)
Brevo__FromEmail=info@honey-cosmetic.com
Brevo__FromName=Honey Cosmetics
Brevo__ReplyToEmail=info@honey-cosmetic.com
Brevo__AdminEmail=your-inbox@example.com
# Per-namena From (opciono; ako prazno → koristi Brevo__FromEmail)
Brevo__CollaborationFromEmail=marketing@honey-cosmetic.com
Brevo__ComplaintsFromEmail=kontakt@honey-cosmetic.com

# --- Make.com (nova porudžbina → HTTP POST webhook) ---
# Prazno = isključeno.
MakeWebhook__WebhookUrl=https://hook.eu1.make.com/1x7xd23hawo8d9f0wqk3wovm83u7ggli

# --- URLs (optional — leave empty for auto-detect from request Host header) ---
# FrontendUrl=https://honey-cosmetic.com
# PublicApiUrl=https://honey-cosmetic.com

# --- CORS (optional extra origins, comma-separated in appsettings array format) ---
# CorsOrigins__0=https://honey-cosmetic.com
# CorsOrigins__1=https://www.honey-cosmetic.com
