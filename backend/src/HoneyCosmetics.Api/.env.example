# Linkovi u emailu (potvrda registracije, reset lozinke).
# PREPORUKA: ostavi prazno — backend AUTOMATSKI koristi domen sa kog je stigao zahtev.
# FrontendUrl=https://honey-cosmetic.com
# PublicApiUrl=https://honey-cosmetic.com
# Samo za lokalni test:
# FrontendUrl=http://localhost:5173

# --- Brevo (domain authentication on honey-cosmetic.com) ---
# API key: Brevo → SMTP & API → API keys
Brevo__ApiKey=your-brevo-api-key
Brevo__FromEmail=info@honey-cosmetic.com
Brevo__FromName=Honey Cosmetics
Brevo__ReplyToEmail=info@honey-cosmetic.com
Brevo__AdminEmail=your-inbox@example.com
Brevo__CollaborationFromEmail=marketing@honey-cosmetic.com
Brevo__ComplaintsFromEmail=kontakt@honey-cosmetic.com
