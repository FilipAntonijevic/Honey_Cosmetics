ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=honey_cosmetics;Username=postgres;Password=postgres
Jwt__Issuer=HoneyCosmetics
Jwt__Audience=HoneyCosmeticsClient
Jwt__Secret=CHANGE_THIS_TO_A_LONG_STRONG_SECRET_KEY_2026
# Admin nalozi (appsettings Admin:Accounts ili env niz):
# Admin__Accounts__0__Email=admin@example.com
# Admin__Accounts__0__Password=your-secure-password
# Admin__Accounts__0__FirstName=Ime
# Admin__Accounts__0__LastName=Prezime
# Linkovi u emailu (potvrda registracije, reset lozinke).
# PREPORUKA: ostavi prazno (ne postavljaj ove varijable) — backend AUTOMATSKI
# koristi domen sa kog je stigao zahtev. Tako radi i sad na Hetzner adresi i
# automatski na https://honeycosmetics.rs čim prebaciš DNS, bez ikakve izmene.
# Postavi ih SAMO ako želiš da forsiraš tačan domen:
# FrontendUrl=https://honeycosmetics.rs
# PublicApiUrl=https://honeycosmetics.rs
# Samo za lokalni test:
# FrontendUrl=http://localhost:5173
SendGrid__ApiKey=your-sendgrid-api-key
SendGrid__FromEmail=noreply@honeycosmetics.rs
SendGrid__FromName=Honey Cosmetics
# Obavezno: u SendGrid-u verifikuj domen honeycosmetics.rs (Domain Authentication)
# i dodaj CNAME + SPF zapise u DNS pre produkcije.
